<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10">
        <h1 class="text-3xl mb-5 font-bold text-white">Create Account</h1>
        <form action="/register" method="post" class="flex gap-3 flex-col items-start">
            <input class="outline-none px-3 py-2 bg-zinc-800 text-white bg-transparent w-full rounded-md" type="text"
                placeholder="Name" name="name">
            <input class="outline-none px-3 py-2 bg-zinc-800 text-white bg-transparent w-full rounded-md" type="text"
                placeholder="username" name="username">
            <input class="outline-none px-3 py-2 bg-zinc-800 text-white bg-transparent w-full rounded-md"
                type="password" placeholder="Password" name="password">
            <input class="outline-none px-3 py-2 bg-zinc-800 text-white bg-transparent w-full rounded-md" type="email"
                name="email" placeholder="Email">
            <input class="outline-none px-3 py-2 bg-zinc-800 text-white bg-transparent w-full rounded-md" type="number"
                placeholder="Age" name="age">
            <input class="bg-blue-400 px-3 py-2 rounded-md cursor-pointer" type="submit" value="Create Account">
            <p class="text-white">Already User ? <a class="text-blue-400" href="/login">Login</a></p>
        </form>
    </div>
</body>

</html>