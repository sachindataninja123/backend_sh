<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10">
        <h1 class="text-3xl mb-5 font-bold">Login your Account</h1>
        <form action="/login" method="post" class="flex gap-3 flex-col items-start">
            <input class="outline-none px-3 py-2 bg-zinc-800 text-white bg-transparent w-full rounded-md" type="email"
                name="email" placeholder="email">
            <input class="outline-none px-3 py-2 bg-zinc-800 text-white bg-transparent w-full rounded-md"
                type="password" placeholder="password" name="password">
            <input class="bg-blue-400 px-3 py-2 rounded-md cursor-pointer" type="submit" value="Login Account">
        </form>
    </div>
</body>

</html>