<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <h5 class="mb-5">Update your post.</h5>
        <form action="/update/<%= post._id%>" method="post">
            <textarea placeholder="What's on your mind ? "
                class="resize-none w-1/3 h-15  border-zinc-800 border-2 outline-none px-2 py-1 rounded-md block"
                name="content" id=""><%= post.content%></textarea>
            <input type="submit" class="bg-yellow-600 text-white rounded-md px-3 py-2 w-40 block mt-5 cursor-pointer"
                value="Update post">
        </form>



    </div>
</body>

</html>