<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <div class="flex justify-end">
            <a href="/logout" class="bg-red-500 py-2 px-4 rounded-md text-sm  ">Logout</a>
        </div>
        <h1 class="text-3xl  font-semibold text-white"><span class="text-gray-300">Hello</span>, <%= user.name%> 👋
        </h1>
        <h5 class="mb-5">You can create a new post.</h5>
        <form action="/post" method="post">
            <textarea placeholder="What's on your mind ? "
                class="resize-none w-1/3 h-15  border-zinc-800 border-2 outline-none px-2 py-1 rounded-md block"
                name="content" id=""></textarea>
            <input type="submit" class="bg-blue-500 text-white rounded-md px-3 py-2 w-40 block mt-5 cursor-pointer"
                value="Create your post">
        </form>

        <div class="posts mt-20">
            <h3 class="text-zinx-400 text-xl">Your posts.</h3>
            <div class="flex flex-wrap gap-3">
                <% user.posts.reverse().forEach((post)=> { %>
                    <div class="mt-5  border-zinc-800 border-[1px] rounded-md p-3 w-1/3 bg-zinc-800">
                        <h4 class="text-blue-400 mb-3">@<%= user.username %>
                        </h4>
                        <p class="tracking-tight text-sm">
                            <%= post.content %>
                        </p>
                        <small class="mt-2 inline-block">
                            <%= post.likes.length%> Likes
                        </small>
                        <div class="flex mt-1 gap-5">
                            <a class="text-blue-400" href="/like/<%= post._id %>">
                                <%= post.likes.indexOf(user._id)==-1 ? "Like" : "Unlike" %>
                            </a>
                            <p class="text-zinc-500">Edit</p>
                        </div>
                    </div>
                    <% }) %>

            </div>

        </div>

    </div>
</body>

</html>