<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        <h1 class="text-3xl font-semibold mb-5">Login your Account</h1>
        <form action="/login" method="post" class="flex flex-col gap-3">
            <input type="email" placeholder="email" name="email" class="bg-zinc-800 px-2 py-2 rounded-md outline-none">
            <input type="password" placeholder="password" name="password"
                class="bg-zinc-800 px-2 py-2 rounded-md outline-none">
            <input type="submit" name="submit" id="" value="Login User"
                class="bg-blue-600 px-4 py-2 rounded-md cursor-pointer">
            <p class="text-sm">New Account , <a class="text-blue-500 underline" href="/">Register</a></p>
        </form>
    </div>
</body>

</html>